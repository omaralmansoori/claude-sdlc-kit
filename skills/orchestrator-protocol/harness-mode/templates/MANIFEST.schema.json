{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrator-protocol.local/harness-mode/MANIFEST.schema.json",
  "title": "Orchestrator-Protocol Harness Task Manifest",
  "description": "Canonical task list for a harness-tier project. Generated by task-architect.yaml. Lifted from Project Dashboard's MANIFEST.schema.json with the wave_plan extended for explicit max_parallel.",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "version": { "type": "string" },
    "generated_at": { "type": ["string", "null"], "format": "date-time" },
    "generated_by": { "type": ["string", "null"] },
    "source_commit": { "type": ["string", "null"] },
    "task_count": { "type": "integer", "minimum": 0 },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/Task" }
    },
    "wave_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wave", "priority"],
        "properties": {
          "wave": { "type": "integer" },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "modules": { "type": "array", "items": { "type": "string" } },
          "max_parallel": { "type": "integer", "minimum": 1, "default": 6 }
        }
      }
    },
    "coverage_summary": {
      "type": "object",
      "properties": {
        "total_sd_items": { "type": "integer" },
        "covered": { "type": "integer" },
        "partial": { "type": "integer" },
        "deferred": { "type": "integer" },
        "superseded": { "type": "integer" },
        "out_preserved": { "type": "integer" },
        "pending": { "type": "integer" }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "Task": {
      "type": "object",
      "required": ["id", "title", "module", "domain", "priority", "complexity", "stage", "depends_on", "suggested_agent", "ui_weight"],
      "properties": {
        "id": { "type": "string", "pattern": "^TASK-[0-9]{4}(?:\\.[0-9]+)?$" },
        "title": { "type": "string" },
        "module": { "type": "string" },
        "sd_items": { "type": "array", "items": { "type": "string", "pattern": "^SD-[0-9]{3}$" } },
        "domain": { "enum": ["frontend", "backend", "data", "infra", "integration", "qa", "docs", "design", "security", "perf"] },
        "priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "complexity": { "enum": ["S", "M", "L", "XL"] },
        "stage": { "enum": ["backlog", "in-progress", "review", "polish", "qa", "done", "blocked"] },
        "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^TASK-[0-9]{4}(?:\\.[0-9]+)?$" } },
        "blocks": { "type": "array", "items": { "type": "string", "pattern": "^TASK-[0-9]{4}(?:\\.[0-9]+)?$" } },
        "suggested_agent": { "type": "string", "description": "Name of an agent profile under agent-profiles/ — the orchestrator uses this as the subagent_type hint." },
        "checkpoint_candidate": { "type": "boolean" },
        "ui_weight": { "enum": ["none", "light", "heavy"], "description": "Drives whether the polish gate runs." },
        "user_surfaces": { "type": "array", "items": { "type": "string" } },
        "existing_app_touchpoints": { "type": "array", "items": { "type": "string" } },
        "existing_flows_at_risk": { "type": "array", "items": { "type": "string" } },
        "defaults_applied": { "type": "array", "items": { "type": "string", "pattern": "^DEF-" } },
        "created": { "type": "string", "format": "date" },
        "session_id": { "type": "string", "description": "When the task is in_progress, the orchestrator session_id that picked it up. Cleared on move to done|blocked." }
      }
    }
  }
}
